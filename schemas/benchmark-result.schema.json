{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flex-translate.local/schemas/benchmark-result.schema.json",
  "title": "FlexTranslateBenchmarkResult",
  "type": "object",
  "required": [
    "goal_id",
    "result_type",
    "support_decision",
    "device_model",
    "os_version",
    "device_tier",
    "model_id",
    "runtime_id",
    "package_size_mb",
    "memory_peak_mb",
    "battery_delta_percent_30m",
    "thermal_result"
  ],
  "properties": {
    "goal_id": { "type": "string" },
    "result_type": { "type": "string", "enum": ["asr", "mt"] },
    "support_decision": { "type": "string", "enum": ["supported", "unsupported", "not_claimed", "needs_review"] },
    "device_model": { "type": "string", "minLength": 1 },
    "os_version": { "type": "string", "minLength": 1 },
    "device_tier": { "type": "string", "enum": ["low", "mid", "high"] },
    "language": { "type": "string" },
    "language_pair": { "type": "string" },
    "model_id": { "type": "string", "minLength": 1 },
    "runtime_id": { "type": "string", "minLength": 1 },
    "package_size_mb": { "type": "number", "minimum": 0 },
    "wer": { "type": ["number", "null"], "minimum": 0 },
    "cer": { "type": ["number", "null"], "minimum": 0 },
    "rtf": { "type": ["number", "null"], "minimum": 0 },
    "p95_partial_latency_ms": { "type": ["number", "null"], "minimum": 0 },
    "quality_metric": { "type": ["string", "null"] },
    "quality_score": { "type": ["number", "null"] },
    "p95_translation_latency_ms": { "type": ["number", "null"], "minimum": 0 },
    "memory_peak_mb": { "type": "number", "minimum": 0 },
    "battery_delta_percent_30m": { "type": "number", "minimum": 0 },
    "thermal_result": { "type": "string", "enum": ["nominal", "fair", "serious_recovered", "critical", "not_measured"] },
    "audio_dropouts": { "type": ["integer", "null"], "minimum": 0 },
    "legal_review_status": { "type": ["string", "null"], "enum": ["not_required", "not_reviewed", "approved_for_distribution", "internal_only", "blocked", null] },
    "evidence_paths": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
